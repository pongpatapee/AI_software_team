# Google Gemini API key — required for real LLM agent calls
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Model to use for all agents (default: gemini-2.0-flash)
# AI_TEAM_MODEL=gemini-2.0-flash

# Langfuse observability — optional, runs fall back gracefully without these
# Get keys at https://cloud.langfuse.com or your self-hosted instance
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Test override — set to "fake" to bypass real LLM calls in CLI tests
# AI_TEAM_TEST_MODEL=fake
